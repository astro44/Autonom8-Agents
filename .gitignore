# Agent Template Directory .gitignore

# ====================
# Agent Testing
# ====================
test_outputs/
test_runs/
*.test.log

# ====================
# OS Files
# ====================
**/.DS_Store
Thumbs.db

# ====================
# Dependencies
# ====================
**/node_modules/
**/bun.lock
**/package-lock.json

# ====================
# Cache & Temp
# ====================
.cache/
*.tmp
*.bak
*.backup
*~

# ====================
# IDE Files
# ====================
.idea/
.vscode/
*.sublime-*

# ====================
# Agent Index (generated)
# ====================
agent-index.json.bak

# ====================
# Keep Agent Definitions
# ====================
!**/*.md
!agent-index.json