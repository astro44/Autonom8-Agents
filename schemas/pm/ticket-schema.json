{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonom8.dev/schemas/pm/ticket.v1.json",
  "title": "PM Ticket Schema",
  "description": "Schema for tickets processed by the PM agent",
  "type": "object",
  "required": ["id", "title", "type"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z]+-[0-9]+$",
      "description": "Unique ticket identifier (e.g., FEAT-123, BUG-456)",
      "examples": ["FEAT-123", "BUG-456", "INC-789"]
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 200,
      "description": "Short descriptive title"
    },
    "type": {
      "type": "string",
      "enum": [
        "feature",
        "bug",
        "incident",
        "tech_debt",
        "documentation",
        "security",
        "compliance",
        "infrastructure"
      ],
      "description": "Type of work item"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the work"
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "default": "medium",
      "description": "Severity/urgency level"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "incidents", "deferred"],
      "description": "Calculated priority after PM scoring"
    },
    "reach": {
      "type": "number",
      "minimum": 0,
      "description": "Number of users/systems affected (RICE model)"
    },
    "impact": {
      "type": "number",
      "minimum": 0,
      "maximum": 3,
      "description": "Business impact score: 0.25=minimal, 0.5=low, 1=medium, 2=high, 3=massive"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence level (0.0-1.0)"
    },
    "effort": {
      "type": "number",
      "minimum": 0.1,
      "description": "Estimated effort in person-days"
    },
    "rice_score": {
      "type": "number",
      "minimum": 0,
      "description": "Calculated RICE score: (reach × impact × confidence) / effort"
    },
    "ice_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "Calculated ICE score: (impact + confidence + ease) / 3"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when ticket was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when ticket was last updated"
    },
    "scored_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when PM agent scored this ticket"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "Target completion date"
    },
    "sla_breach_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when SLA will be breached"
    },
    "status": {
      "type": "string",
      "enum": [
        "inbox",
        "triage",
        "backlog",
        "in_progress",
        "blocked",
        "review",
        "completed",
        "deferred",
        "cancelled"
      ],
      "default": "inbox",
      "description": "Current status"
    },
    "blocked_by": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z]+-[0-9]+$"
      },
      "description": "List of ticket IDs blocking this work"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z]+-[0-9]+$"
      },
      "description": "List of ticket IDs this work depends on"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Categorization tags"
    },
    "assignee": {
      "type": "string",
      "description": "Person or team assigned"
    },
    "reporter": {
      "type": "string",
      "description": "Person who reported/created the ticket"
    },
    "source": {
      "type": "string",
      "enum": [
        "monitor",
        "analyst",
        "user_report",
        "github",
        "jira",
        "manual",
        "voice_helpdesk"
      ],
      "description": "How this ticket entered the system"
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata",
      "properties": {
        "tenant": {
          "type": "string",
          "description": "Tenant identifier"
        },
        "category": {
          "type": "string",
          "description": "Business category"
        },
        "component": {
          "type": "string",
          "description": "System component affected"
        },
        "external_id": {
          "type": "string",
          "description": "ID in external system (GitHub, Jira, etc.)"
        },
        "external_url": {
          "type": "string",
          "format": "uri",
          "description": "Link to external ticket"
        }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "action": {
            "type": "string"
          },
          "actor": {
            "type": "string"
          },
          "changes": {
            "type": "object"
          }
        }
      },
      "description": "Audit trail of changes"
    }
  }
}
