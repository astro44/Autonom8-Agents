{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonom8.dev/schemas/pm/proposal.v2.json",
  "title": "PM/PO Proposal Schema v2.0",
  "description": "Schema for proposals processed through PM↔PO enrichment loop (story recommendations phase)",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "title",
    "description",
    "type",
    "priority",
    "state",
    "workflow_step",
    "context",
    "metadata",
    "po_enrichment",
    "pm_review"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["2.0"],
      "description": "Schema version for migration tracking"
    },
    "id": {
      "type": "string",
      "pattern": "^PROP-[A-Z]+-[0-9]+-[A-Z0-9-]+$",
      "description": "Unique proposal identifier",
      "examples": ["PROP-OXY-001-AUTH-SYSTEM", "PROP-AMB-042-DASHBOARD"]
    },
    "title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "Descriptive proposal title"
    },
    "description": {
      "type": "string",
      "minLength": 50,
      "description": "Detailed proposal description"
    },
    "type": {
      "type": "string",
      "enum": ["feature", "enhancement", "bug", "refactor", "infrastructure", "documentation"],
      "description": "Type of work proposed"
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3"],
      "description": "Priority level (P0=critical, P3=low)"
    },
    "state": {
      "type": "string",
      "enum": [
        "pending",
        "strategic_review",
        "vision_enrichment",
        "stories_enrichment",
        "sprint_ready",
        "rejected",
        "deferred"
      ],
      "description": "Current workflow state"
    },
    "workflow_step": {
      "type": "string",
      "enum": [
        "pending",
        "pm_strategic_review",
        "po_vision_enrichment",
        "pm_vision_review",
        "po_stories_enrichment",
        "pm_stories_review",
        "sprint_ready",
        "rejected",
        "deferred"
      ],
      "description": "Specific workflow step within state"
    },
    "context": {
      "type": "object",
      "required": ["current_state", "business_impact", "estimated_effort", "dependencies"],
      "properties": {
        "current_state": {
          "type": "string",
          "minLength": 20,
          "description": "Current system state or problem"
        },
        "business_impact": {
          "type": "string",
          "minLength": 20,
          "description": "Expected business value"
        },
        "estimated_effort": {
          "type": "string",
          "description": "Effort estimate (hours/days/story points)"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "External dependencies or blockers"
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["source", "stakeholders", "tags", "created_at", "updated_at"],
      "properties": {
        "source": {
          "type": "string",
          "description": "Where this proposal originated"
        },
        "stakeholders": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "People or teams involved"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Categorization tags"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Proposal creation timestamp"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        }
      }
    },
    "po_enrichment": {
      "type": "object",
      "required": ["stories", "vision"],
      "properties": {
        "stories": {
          "type": "object",
          "required": ["user_stories"],
          "properties": {
            "user_stories": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["id", "title", "description", "acceptance_criteria", "priority"],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^US-[0-9]+$",
                    "description": "User story identifier"
                  },
                  "title": {
                    "type": "string",
                    "minLength": 10,
                    "maxLength": 200,
                    "description": "Story title"
                  },
                  "description": {
                    "type": "string",
                    "minLength": 20,
                    "description": "As a [user], I want [goal] so that [benefit]"
                  },
                  "acceptance_criteria": {
                    "type": "array",
                    "minItems": 2,
                    "items": {
                      "type": "string"
                    },
                    "description": "Testable acceptance criteria"
                  },
                  "priority": {
                    "type": "string",
                    "enum": ["P0", "P1", "P2", "P3"],
                    "description": "Story priority"
                  },
                  "technical_considerations": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Technical implementation notes (Codex enrichment)"
                  },
                  "estimated_hours": {
                    "type": "number",
                    "minimum": 0,
                    "description": "Effort in hours (Codex enrichment)"
                  },
                  "story_points": {
                    "type": "number",
                    "minimum": 0,
                    "description": "Story points (OpenCode enrichment)"
                  },
                  "definition_of_done": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Completion criteria (Codex enrichment)"
                  }
                }
              }
            },
            "epic_summary": {
              "type": "string",
              "description": "High-level epic summary (OpenCode enrichment)"
            },
            "sprint_breakdown": {
              "type": "object",
              "description": "Sprint allocation recommendations (Codex enrichment)",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "vision": {
          "type": "object",
          "required": ["recommendation", "reasoning", "strategic_alignment", "next_steps"],
          "properties": {
            "recommendation": {
              "type": "string",
              "enum": ["proceed", "refine", "defer", "reject"],
              "description": "PO recommendation"
            },
            "reasoning": {
              "type": "string",
              "minLength": 50,
              "description": "Rationale for recommendation"
            },
            "strategic_alignment": {
              "type": "string",
              "minLength": 20,
              "description": "How this aligns with strategy"
            },
            "next_steps": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              },
              "description": "Recommended actions"
            },
            "scores": {
              "type": "object",
              "description": "Quality scores (Claude enrichment)",
              "properties": {
                "innovation_potential": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 10
                },
                "clarity": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 10
                },
                "user_impact": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 10
                }
              }
            },
            "risk_assessment": {
              "type": "object",
              "description": "Risk analysis (Claude enrichment)",
              "properties": {
                "technical_risks": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "business_risks": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "mitigation_strategies": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "testing_strategy": {
              "type": "string",
              "description": "Testing approach (Codex enrichment)"
            },
            "market_validation": {
              "type": "string",
              "description": "Market research notes (Codex enrichment)"
            }
          }
        },
        "vision_review": {
          "type": "string",
          "description": "Gemini vision review (compatibility field)"
        }
      }
    },
    "pm_review": {
      "type": "object",
      "required": ["decision", "phase", "priority", "reasoning", "timeline", "success_metrics"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["approved", "needs_revision", "rejected", "deferred"],
          "description": "PM decision"
        },
        "phase": {
          "type": "string",
          "enum": ["strategic", "vision", "stories"],
          "description": "Review phase"
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"],
          "description": "PM-assigned priority"
        },
        "reasoning": {
          "type": "string",
          "minLength": 100,
          "description": "Detailed rationale for decision"
        },
        "timeline": {
          "type": "string",
          "description": "Recommended timeline (e.g., 'Sprint 23')"
        },
        "success_metrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "description": "Measurable success criteria"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "description", "blocking"],
            "properties": {
              "type": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "blocking": {
                "type": "boolean"
              }
            }
          },
          "description": "Conditions for approval (Claude enrichment)"
        },
        "resource_requirements": {
          "type": "object",
          "description": "Team resource needs (Codex enrichment)",
          "properties": {
            "developers": {
              "type": "number",
              "minimum": 0
            },
            "designers": {
              "type": "number",
              "minimum": 0
            },
            "qa": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "priority_adjustment": {
          "type": "object",
          "description": "Priority changes (OpenCode enrichment)",
          "properties": {
            "original": {
              "type": "string"
            },
            "adjusted": {
              "type": "string"
            },
            "reason": {
              "type": "string"
            }
          }
        }
      }
    },
    "processing_metadata": {
      "type": "object",
      "description": "LLM processing tracking",
      "properties": {
        "providers_used": {
          "type": "object",
          "description": "Which providers handled each phase",
          "properties": {
            "strategic_review": {
              "type": "string",
              "enum": ["claude", "codex", "gemini", "opencode"]
            },
            "vision_enrichment": {
              "type": "string",
              "enum": ["claude", "codex", "gemini", "opencode"]
            },
            "stories_enrichment": {
              "type": "string",
              "enum": ["claude", "codex", "gemini", "opencode"]
            }
          }
        },
        "total_cost_usd": {
          "type": "number",
          "minimum": 0,
          "description": "Total LLM API costs"
        },
        "total_duration_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Total processing time"
        },
        "iterations": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of PM↔PO cycles"
        }
      }
    }
  }
}
